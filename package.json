{
  "name": "olx-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Персональна система моніторингу оголошень OLX.ua",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm -w server run dev",
    "dev:web": "npm -w web run dev",
    "build": "npm -w server run build && npm -w web run build",
    "scan": "npm -w server run scan --"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
