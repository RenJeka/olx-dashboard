# OAuth 2.0 Client ID з Google Cloud Console (Web application). Той самий, що GOOGLE_CLIENT_ID
# на сервері. Authorized JavaScript origins = домен фронта + http://localhost:5173.
VITE_GOOGLE_CLIENT_ID=

# Базовий URL API. Локально лишити порожнім — Vite-проксі веде /api на :3001.
# У проді (фронт і API на різних доменах Render): https://<api-service>.onrender.com
VITE_API_BASE=
