# OpenRouter — ключ для авто-режиму LLM-аналізу (опціонально).
# Без ключа працює повний ручний режим (копіювання промпту → безкоштовний чат → вставка).
# Отримати ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Persistence: Turso (libSQL) ──────────────────────────────────────────────
# Локально (за замовчуванням) можна НЕ ставити — db.ts відкриває file:server/data/olx.db.
# Щоб явно вказати локальний файл: TURSO_DATABASE_URL=file:server/data/olx.db
# Прод (Turso): TURSO_DATABASE_URL=libsql://<db>-<org>.turso.io + TURSO_AUTH_TOKEN.
TURSO_DATABASE_URL=
# Auth-токен Turso (для file: НЕ потрібен; ніколи не комітити реальний токен).
TURSO_AUTH_TOKEN=

# CORS: origin фронтенду (Static Site на Render). Локально дефолт — http://localhost:5173.
# Для cross-site сесійної кукі має бути ЯВНИЙ домен (не *).
WEB_ORIGIN=

# ── Auth: Google OAuth «ворота» (single-user gate) ───────────────────────────
# Пускає лише власника. НЕ мультиюзер: жодної таблиці users, жодного user_id у даних.
# OAuth 2.0 Client ID з Google Cloud Console (Web application; Authorized JavaScript
# origins = домен фронта + http://localhost:5173).
GOOGLE_CLIENT_ID=
# Allowlist email (comma-sep). Для single-user — одна своя адреса.
ALLOWED_EMAILS=
# Довгий випадковий рядок для підпису сесійного JWT (ніколи не комітити реальний).
SESSION_SECRET=
# Secure-кукі. Дефолт true (прод/HTTPS). false — лише для локального http://localhost.
AUTH_COOKIE_SECURE=true
# Локальний обхід авторизації (тільки dev): true вимикає замок повністю. У проді — НЕ ставити.
AUTH_DISABLED=
